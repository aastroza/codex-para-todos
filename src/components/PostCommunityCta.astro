---
interface Props {
  lang?: "es" | "en";
}

const { lang = "es" } = Astro.props;
const copy = lang === "en"
  ? {
      title: "Join the community",
      text: "Subscribe to the newsletter and join our WhatsApp group.",
      action: "Go to community",
    }
  : {
      title: "Súmate a la comunidad",
      text: "Inscríbete al boletín de noticias y a nuestro grupo de WhatsApp.",
      action: "Ir a comunidad",
    };
---

<section class="post-community-section" aria-labelledby="post-community-title">
  <div class="container">
    <div class="post-community-panel">
      <div>
        <h2 id="post-community-title">{copy.title}</h2>
        <p>
          {copy.text}
        </p>
      </div>
      <a class="button button-primary" href="/comunidad/">{copy.action}</a>
    </div>
  </div>
</section>
