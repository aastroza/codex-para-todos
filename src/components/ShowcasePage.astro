---
import SiteLayout from "../layouts/SiteLayout.astro";

type Lang = "es" | "en";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const isEnglish = lang === "en";
const demoBasePath = "/images/demo-screenshots";

const projectBase = [
  {
    name: "Calendaris",
    team: "Nicolás Soto",
    fieldEs: "Ingeniería Civil Informática e Inteligencia Artificial",
    fieldEn: "Computer Science and Artificial Intelligence",
    url: "https://calendaris-inky.vercel.app/",
    summaryEs:
      "Calendario universitario con ramos, evaluaciones, eventos y bloques de estudio sugeridos.",
    summaryEn:
      "A university calendar for courses, evaluations, events and suggested study blocks.",
    theme: "sky",
    demoImages: [
      {
        src: `${demoBasePath}/calendaris-01-portada.png`,
        altEs: "Portada de Calendaris con calendario académico y acceso",
        altEn: "Calendaris cover screen with academic calendar and access panel",
      },
      {
        src: `${demoBasePath}/calendaris-02-login.png`,
        altEs: "Pantalla de inicio de sesión de Calendaris",
