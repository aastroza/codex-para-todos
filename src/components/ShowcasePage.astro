    theme: "violet",
    demoImages: [
      {
        src: `${demoBasePath}/studybrain-01-portada.png`,
        altEs: "Pantalla de acceso de StudyBrain",
        altEn: "StudyBrain access screen",
      },
      {
        src: `${demoBasePath}/studybrain-02-login-o-flujo.png`,
        altEs: "Formulario de inicio de sesión de StudyBrain",
        altEn: "StudyBrain sign-in form",
      },
    ],
  },
  {
    name: "BriefLab",
    team: "Amelia Troncoso",
    fieldEs: "Diseño Gráfico",
    fieldEn: "Graphic Design",
    url: "https://brief-lab.vercel.app",
    summaryEs:
      "Generador de briefs ficticios para practicar diseño y construir portafolio sin clientes reales.",
    summaryEn:
      "A fictional brief generator for design practice and portfolio building without real clients.",
    theme: "rose",
    demoImages: [
      {
        src: `${demoBasePath}/brieflab-01-portada.png`,
        altEs: "Portada de BriefLab",
        altEn: "BriefLab cover screen",
      },
      {
        src: `${demoBasePath}/brieflab-02-flujo.png`,
        altEs: "Selección de área en BriefLab",
        altEn: "BriefLab area selection flow",
      },
    ],
  },
  {
    name: "FinEx",
    team: "Sebastián Ramírez",
    fieldEs: "Ingeniería Civil Industrial",
    fieldEn: "Industrial Engineering",
    url: "https://finex-public-frontend.vercel.app",
    summaryEs:
      "Finanzas personales local-first: importa avisos de Gmail, clasifica gastos y visualiza presupuesto.",
    summaryEn:
      "A local-first personal finance app that imports Gmail notices, classifies expenses and visualizes budgets.",
    theme: "green",
    demoImages: [
      {
        src: `${demoBasePath}/finex-01-portada.png`,
        altEs: "Portada de FinEx",
        altEn: "FinEx cover screen",
      },
      {
        src: `${demoBasePath}/finex-02-demo-dashboard.png`,
        altEs: "Dashboard de modo demo de FinEx",
        altEn: "FinEx demo mode dashboard",
      },
      {
        src: `${demoBasePath}/finex-03-importar.png`,
        altEs: "Vista de importación de correos en FinEx",
        altEn: "FinEx email import view",
      },
      {
        src: `${demoBasePath}/finex-03-movimiento.png`,
        altEs: "Vista de movimientos en FinEx",
        altEn: "FinEx movements view",
      },
      {
        src: `${demoBasePath}/finex-03-obligaciones.png`,
        altEs: "Vista de obligaciones en FinEx",
        altEn: "FinEx obligations view",
      },
    ],
  },
  {
    name: "Fit Me",
    team: "Diego Rivera y Valentina Castillo",
    fieldEs: "Psicología y Odontología",
    fieldEn: "Psychology and Dentistry",
    url: "/images/fit-me-codex-automation.jpg",
    ctaLabel: "Demo",
    summaryEs:
      "Automatización en Codex que arma siete outfits semanales con ropa real, estilo y clima.",
    summaryEn:
      "A Codex automation that prepares seven weekly outfits from real clothing, style references and weather.",
    theme: "amber",
    demoImages: [
      {
        src: `${demoBasePath}/fit-me-02-propuesta-final.jpg`,
        altEs: "Resultado visual de outfits semanales de Fit Me",
        altEn: "Fit Me weekly outfit visual result",
      },
    ],
  },
  {
    name: "RubricaCheck",
    team: "José Tomás Cifuentes",
    fieldEs: "Ingeniería Civil Obras Civiles",
    fieldEn: "Civil Engineering",
    url: "https://rubricacheck-mvp.vercel.app",
    summaryEs:
      "App web que convierte rúbricas e instrucciones en una estructura clara para preparar entregas.",
    summaryEn:
      "A web app that turns rubrics and assignment instructions into a clearer structure for submissions.",
    theme: "blue",
    demoImages: [
      {
        src: `${demoBasePath}/rubricacheck-01-portada.png`,
        altEs: "Portada de RubricaCheck",
        altEn: "RubricaCheck cover screen",
      },
      {
        src: `${demoBasePath}/rubricacheck-02-ejemplo-o-formulario.png`,
        altEs: "Ejemplo cargado en RubricaCheck",
        altEn: "RubricaCheck loaded example",
      },
    ],
  },
];

const projects = projectBase.map((project) => ({
  name: project.name,
  team: project.team,
  field: isEnglish ? project.fieldEn : project.fieldEs,
  url: project.url,
  ctaLabel: project.ctaLabel,
  summary: isEnglish ? project.summaryEn : project.summaryEs,
  theme: project.theme,
  demoImages: project.demoImages.map((image) => ({
    src: image.src,
    alt: isEnglish ? image.altEn : image.altEs,
    focus: image.focus,
  })),
}));

const careers = isEnglish
  ? [
      ["Commercial Engineering", "9"],
      ["Global Business Administration", "3"],
      ["Architecture", "3"],
      ["Dentistry", "2"],
      ["Medical Technology", "2"],
      ["Computer Science and AI", "2"],
      ["Psychology", "2"],
      ["Computer Science and Technological Innovation", "1"],
      ["Law", "1"],
      ["Civil Engineering", "1"],
      ["Political Science and Public Policy", "1"],
      ["Industrial Engineering", "1"],
      ["Kinesiology", "1"],
      ["Design", "1"],
    ]
  : [
      ["Ingeniería Comercial", "9"],
      ["Global Business Administration", "3"],
      ["Arquitectura", "3"],
      ["Odontología", "2"],
      ["Tecnología Médica", "2"],
      ["Ing. Civil Informática e IA", "2"],
      ["Psicología", "2"],
      ["Ing. Civil Informática e Innovación Tecnológica", "1"],
      ["Derecho", "1"],
      ["Ingeniería Civil Obras Civiles", "1"],
      ["Ciencia Política y Políticas Públicas", "1"],
      ["Ingeniería Civil Industrial", "1"],
      ["Kinesiología", "1"],
      ["Diseño", "1"],
    ];

const challenges = isEnglish
  ? [
      {
        theme: "Academic planning",
        problem: "Dates, courses, evaluations and study time were scattered.",
        solution:
          "Academic calendars, weekly planners, prioritization by urgency or difficulty and suggested study blocks.",
      },
      {
        theme: "Instructions and material",
        problem: "Rubrics, assignments, notes and summaries were long or unclear.",
        solution:
          "Apps that simplify instructions, extract requirements and generate study guides, flashcards or review plans.",
      },
      {
        theme: "Wellbeing and habits",
        problem: "Procrastination, overload, anxiety, lack of sleep and daily time loss.",
        solution:
          "Focus sessions, preventive alerts, realistic schedules, outfit automation and personal organization.",
      },
      {
        theme: "Finance and consumption",
        problem: "Students struggled to control expenses, plan purchases or decide with limited budget.",
        solution:
          "Financial dashboards, expense classifiers, optimized shopping lists and price-benefit recommendations.",
      },
      {
        theme: "Specific career tools",
        problem: "Health, design, advertising and academic evaluation had discipline-specific needs.",
        solution:
          "Generated design briefs, health study simulators, campaign analysis and rubric assistants.",
      },
    ]
  : [
      {
        theme: "Planificación académica",
        problem: "Fechas, ramos, evaluaciones y tiempos de estudio dispersos.",
        solution:
          "Calendarios, planificadores semanales, prioridades y bloques de estudio sugeridos.",
      },
      {
        theme: "Instrucciones y material",
        problem: "Rúbricas, tareas, apuntes y resúmenes largos o poco claros.",
        solution:
          "Apps que simplifican requisitos y generan guías, flashcards o planes de repaso.",
      },
      {
        theme: "Bienestar y hábitos",
        problem: "Procrastinación, sobrecarga, ansiedad, falta de sueño o pérdida de tiempo.",
        solution:
          "Foco, alertas, horarios realistas, automatización de outfits y organización personal.",
      },
      {
        theme: "Finanzas y consumo",
        problem: "Controlar gastos, planificar compras o decidir con presupuesto limitado.",
        solution:
          "Paneles financieros, clasificadores de gasto, listas optimizadas y recomendaciones.",
      },
      {
        theme: "Herramientas por carrera",
        problem: "Necesidades de salud, diseño, publicidad o evaluación académica.",
        solution:
          "Briefs generados, simuladores de estudio, análisis de campañas y asistentes de rúbricas.",
      },
    ];

const agenticTools = isEnglish
  ? [
      {
        title: "A faster path from idea to demo",
        text: "Students described a problem in plain language, then used Codex to turn it into screens, data, rules and a working first version.",
      },
      {
        title: "Iteration became part of the work",
        text: "They tested what broke, narrowed the scope and came back with better instructions. The prototype improved because the student kept making choices.",
      },
      {
        title: "Software could be personal",
        text: "Several projects were not business ideas. They were small tools built for one person's routine, calendar, budget, closet or class. Codex made that kind of custom software realistic.",
      },
      {
        title: "The student still owned the judgment",
        text: "Codex could produce code, but the student chose the problem, set the limits and decided whether the result made sense.",
      },
    ]
  : [
      {
        title: "Codex como compañero de prototipado",
        text: "Lo usaron para pasar de una idea escrita a interfaz, modelo de datos, reglas y demo funcionando.",
      },
      {
        title: "Iterar como método",
        text: "Pidieron una primera versión, probaron qué fallaba, acotaron alcance y volvieron con instrucciones más precisas.",
      },
      {
        title: "Código, pruebas y documentación",
        text: "Codex ayudó a escribir UI, lógica, parsers, almacenamiento local, flujos de API, documentación y pasos de despliegue.",
      },
      {
        title: "El criterio siguió siendo humano",
        text: "El estudiante eligió el problema, decidió los límites y explicó por qué el prototipo tenía sentido.",
      },
    ];

const copy = isEnglish
  ? {
      title: "ExploraTec Showcase",
      description:
        "Student projects built with Codex in XTECC21 Create your AI Agent.",
      canonical: "https://codexparatodos.com/showcase/en/",
      languageLabel: "Español",
      languageHref: "/showcase/",
      course: "XTECC21 Create your AI Agent",
      date: "June 26, 2026",
      intro:
        "built small, working demos from problems they knew firsthand: study planning, rubrics, budgets, habits and workflows from their own fields.",
      courseTitle: "Course data",
      courseText:
        "The course brought together 30 students, 22 projects and 14 majors. Most students were early in their university path, and many did not come from coding. That is what made the work interesting: they used Codex to turn judgment from their own field into a prototype they could test.",
      challengesTitle: "Challenges students found",
      challengesText:
        "The projects show the same practical pattern: students had to turn vague friction into a flow that could be tested.",
      agenticTitle: "What Codex made possible",
      agenticText:
        "Codex worked best as a practical loop: describe the problem, build a version, test it, then make the next instruction sharper.",
      projectsFirstTitle: "Projects 1 to 3",
      projectsSecondTitle: "Projects 4 to 6",
      majorsTitle: "Majors represented",
      projectsTitle: "Student projects",
      problemLabel: "Problem",
      solutionLabel: "Solution",
      contactNote: "For more information, contact the professor:",
      visit: "Open project",
      demo: "Demo",
      closeDemo: "Close demo",
      nextDemo: "Next screenshot",
      previousDemo: "Previous screenshot",
      demoCounter: "Screenshot",
      back: "Back to home",
    }
  : {
      title: "Showcase ExploraTec",
      description:
        "Proyectos estudiantiles creados con Codex en XTECC21 Crea tu Agente de IA.",
      canonical: "https://codexparatodos.com/showcase/",
      languageLabel: "English",
      languageHref: "/showcase/en/",
      course: "XTECC21 Crea tu Agente de IA",
      date: "26 de junio de 2026",
      intro:
        "convirtieron problemas cotidianos en demos con interfaz, reglas y evidencia.",
      courseTitle: "Datos del curso",
      courseText:
        "La muestra reúne estudiantes de 14 carreras. Muchos no venían desde la programación. Justamente por eso el resultado importa: herramientas agénticas les permitieron expresar criterio de su propia disciplina en prototipos funcionales.",
      challengesTitle: "Temáticas, problemas y soluciones",
      challengesText:
        "Los proyectos partieron desde problemas cercanos al día a día y los convirtieron en flujos que se podían probar.",
      agenticTitle: "Cómo usaron herramientas agénticas",
      agenticText:
        "Codex fue más útil cuando entró en un ciclo: especificar, construir, probar, corregir y explicar.",
      projectsFirstTitle: "Proyectos 1 a 3",
      projectsSecondTitle: "Proyectos 4 a 6",
      majorsTitle: "Carreras representadas",
      projectsTitle: "Proyectos estudiantiles",
      problemLabel: "Problema",
      solutionLabel: "Solución",
      contactNote: "Para más información, contacta al profesor:",
      visit: "Abrir proyecto",
      demo: "Demo",
      closeDemo: "Cerrar demo",
      nextDemo: "Siguiente captura",
      previousDemo: "Captura anterior",
      demoCounter: "Captura",
      back: "Volver al inicio",
    };

const demoProjects = projects.map((project) => ({
  name: project.name,
  images: project.demoImages,
}));
---

<SiteLayout title={copy.title} description={copy.description} canonical={copy.canonical} lang={lang}>
  <main class="showcase-page">
    <section class="showcase-hero" aria-labelledby="showcase-title">
      <div class="container showcase-hero-grid">
        <div class="showcase-hero-copy">
          <a class="back-link" href="/">{copy.back}</a>
          <h1 id="showcase-title">{copy.title}</h1>
          <p>
            {isEnglish ? "In the final exam for" : "En el examen final de"} {copy.course},{" "}
            {isEnglish ? "students in" : "estudiantes de"}{" "}
            <a href="https://exploratec.udd.cl" target="_blank" rel="noreferrer">ExploraTec UDD</a>{" "}
            {copy.intro}
          </p>
          <a class="language-switch" href={copy.languageHref} hreflang={isEnglish ? "es" : "en"}>
            {copy.languageLabel}
          </a>
        </div>
      </div>
    </section>

    <section class="showcase-overview" aria-labelledby="activity-title">
      <div class="container showcase-overview-grid showcase-overview-prose">
        <div>
          <h2 id="activity-title">{copy.courseTitle}</h2>
          <p>{copy.courseText}</p>
          <div class="career-list">
            <h3>{copy.majorsTitle}</h3>
            <p>{careers.map(([career]) => career).join(", ")}.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="showcase-insights" aria-labelledby="challenges-title">
      <div class="container showcase-insights-grid">
        <div>
          <h2 id="challenges-title">{copy.challengesTitle}</h2>
          <p>{copy.challengesText}</p>
        </div>
        <div class="insight-copy">
          {challenges.map((item) => (
            <article>
              <h3>{item.theme}</h3>
              <p><strong>{copy.problemLabel}:</strong> {item.problem}</p>
              <p><strong>{copy.solutionLabel}:</strong> {item.solution}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="showcase-insights showcase-agentic" aria-labelledby="agentic-title">
      <div class="container showcase-insights-grid">
        <div>
          <h2 id="agentic-title">{copy.agenticTitle}</h2>
          <p>{copy.agenticText}</p>
        </div>
        <div class="insight-copy">
          {agenticTools.map((item) => (
            <article>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="showcase-projects-section" aria-labelledby="projects-title">
      <div class="container">
        <h2 id="projects-title">{copy.projectsTitle}</h2>
        <div class="showcase-projects">
          {projects.map((project) => (
            <article class="project-card" data-theme={project.theme}>
              <div class="project-card-art" aria-hidden="true"></div>
              <div class="project-card-body">
                <h3>{project.name}</h3>
                <p class="project-team">{project.team}</p>
                <p class="project-field">{project.field}</p>
                <p>{project.summary}</p>
                <div class="project-card-actions">
                  {project.name !== "Fit Me" ? (
                    <a class="project-open-link" href={project.url} target="_blank" rel="noreferrer">
                      {copy.visit}
                    </a>
                  ) : null}
                  <button
                    class="project-demo-button"
                    type="button"
                    data-demo-project={project.name}
                  >
                    {copy.demo}
                  </button>
                </div>
              </div>
            </article>
          ))}
        </div>
        <p class="showcase-contact-note">
          {copy.contactNote}{" "}
          <a href="https://x.com/aastroza" target="_blank" rel="noreferrer">@aastroza</a>
        </p>
      </div>
    </section>
  </main>

  <div class="demo-modal" data-demo-modal data-demo-counter-label={copy.demoCounter} hidden>
    <div class="demo-modal-backdrop" data-demo-close></div>
    <section
      class="demo-modal-panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby="demo-modal-title"
      tabindex="-1"
    >
      <div class="demo-modal-header">
        <div>
          <p data-demo-count>{copy.demoCounter} 1 / 1</p>
          <h2 id="demo-modal-title" data-demo-title></h2>
        </div>
        <button class="demo-modal-close" type="button" data-demo-close aria-label={copy.closeDemo}>
          ×
        </button>
      </div>
      <div class="demo-modal-stage">
        <button class="demo-modal-nav demo-modal-nav-prev" type="button" data-demo-prev aria-label={copy.previousDemo}>
          ‹
        </button>
        <figure class="demo-modal-figure">
          <img data-demo-image src="" alt="" />
        </figure>
        <button class="demo-modal-nav demo-modal-nav-next" type="button" data-demo-next aria-label={copy.nextDemo}>
          ›
        </button>
      </div>
      <div class="demo-modal-thumbs" data-demo-thumbs aria-label="Demo screenshots"></div>
    </section>
  </div>

  <script type="application/json" id="demo-projects-data" set:html={JSON.stringify(demoProjects)} />
  <script is:inline>
    (() => {
      const dataEl = document.getElementById("demo-projects-data");
      const modal = document.querySelector("[data-demo-modal]");
      if (!dataEl || !modal) return;

      const projects = JSON.parse(dataEl.textContent || "[]");
      const title = modal.querySelector("[data-demo-title]");
      const count = modal.querySelector("[data-demo-count]");
      const image = modal.querySelector("[data-demo-image]");
      const thumbs = modal.querySelector("[data-demo-thumbs]");
      const prev = modal.querySelector("[data-demo-prev]");
      const next = modal.querySelector("[data-demo-next]");
      const panel = modal.querySelector(".demo-modal-panel");
      let activeProject = null;
      let activeIndex = 0;
      let lastFocus = null;

      const render = () => {
        if (!activeProject) return;
        const images = activeProject.images;
        const current = images[activeIndex];
        title.textContent = activeProject.name;
        count.textContent = `${modal.dataset.demoCounterLabel} ${activeIndex + 1} / ${images.length}`;
        image.src = current.src;
        image.alt = current.alt;
        image.dataset.focus = current.focus || "";
        prev.disabled = images.length < 2;
        next.disabled = images.length < 2;
        thumbs.replaceChildren(
          ...images.map((item, index) => {
            const button = document.createElement("button");
            button.type = "button";
            button.className = "demo-modal-thumb";
            button.setAttribute("aria-label", `${activeProject.name} ${index + 1}`);
            button.setAttribute("aria-current", index === activeIndex ? "true" : "false");
            button.addEventListener("click", () => {
              activeIndex = index;
              render();
            });

            const thumb = document.createElement("img");
            thumb.src = item.src;
            thumb.alt = "";
            thumb.dataset.focus = item.focus || "";
            button.append(thumb);
            return button;
          }),
        );
      };

      const open = (name, trigger) => {
        activeProject = projects.find((project) => project.name === name);
        if (!activeProject) return;
        activeIndex = 0;
        lastFocus = trigger;
        render();
        modal.hidden = false;
        document.documentElement.classList.add("demo-modal-open");
        requestAnimationFrame(() => panel?.focus());
      };

      const close = () => {
        modal.hidden = true;
        document.documentElement.classList.remove("demo-modal-open");
        lastFocus?.focus();
      };

      const move = (direction) => {
        if (!activeProject || activeProject.images.length < 2) return;
        activeIndex =
          (activeIndex + direction + activeProject.images.length) % activeProject.images.length;
        render();
      };

      document.querySelectorAll("[data-demo-project]").forEach((button) => {
        button.addEventListener("click", () => open(button.dataset.demoProject, button));
      });

      modal.querySelectorAll("[data-demo-close]").forEach((button) => {
        button.addEventListener("click", close);
      });
      prev?.addEventListener("click", () => move(-1));
      next?.addEventListener("click", () => move(1));
      document.addEventListener("keydown", (event) => {
        if (modal.hidden) return;
        if (event.key === "Escape") close();
        if (event.key === "ArrowLeft") move(-1);
        if (event.key === "ArrowRight") move(1);
      });
    })();
  </script>
</SiteLayout>
