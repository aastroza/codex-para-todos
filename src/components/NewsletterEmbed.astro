---
const buttondownSubscribeUrl = "https://buttondown.com/api/emails/embed-subscribe/codexforall";
---

<section id="newsletter" class="newsletter-section" aria-labelledby="newsletter-title">
  <div class="container">
    <div class="newsletter-panel">
      <div class="newsletter-copy">
        <h2 id="newsletter-title">Recibe el boletín</h2>
        <p>
          Ideas, guías y próximos encuentros para aprender a trabajar con Codex sin ser programador.
        </p>
      </div>
      <form class="newsletter-form" action={buttondownSubscribeUrl} method="post">
        <label for="newsletter-email">Correo electrónico</label>
        <div class="newsletter-form-row">
          <input
            id="newsletter-email"
            type="email"
            name="email"
            autocomplete="email"
            inputmode="email"
            placeholder="tu@email.com"
            required
          />
          <button type="submit">Suscribirme</button>
        </div>
        <input type="hidden" value="1" name="embed" />
        <input type="hidden" value="español" name="tag" />
        <input type="hidden" value="es" name="metadata__preferred-language" />
        <p>Usamos Buttondown para enviar el boletín.</p>
      </form>
    </div>
  </div>
</section>
