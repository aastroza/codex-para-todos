---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
}

const siteName = "Codex para todos";
const defaultDescription =
  "Una comunidad para aprender, practicar y compartir cómo trabajar con Codex sin ser programador.";
const defaultOgImage = "https://codexparatodos.com/images/og-card-codex-landscape.png";
const dataScienceUrl = "https://ingenieria.udd.cl/data-science/";
const informaticaUrl =
  "https://ingenieria.udd.cl/carrera/ingenieria-civil-en-informatica-e-innovacion-tecnologica/";

const {
  title = siteName,
  description = defaultDescription,
  canonical,
  ogImage = defaultOgImage,
  ogType = "website",
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://codexparatodos.com");
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const pageTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const isHome = Astro.url.pathname === "/";
const isBlog = Astro.url.pathname.startsWith("/blog");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/logos/codex-color.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="Codex para todos" href="/rss.xml" />
    <meta name="theme-color" content="#ffffff" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Codex para todos: agentes de IA explicados en simple" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href="/" aria-label="Codex para todos">
          <img src="/logos/codex.png" alt="" width="32" height="32" />
          <span>Codex para todos</span>
        </a>
        <nav class="site-nav" aria-label="Navegación principal">
          <a href="/" aria-current={isHome ? "page" : undefined}>Inicio</a>
          <a href="/comunidad/" aria-current={Astro.url.pathname.startsWith("/comunidad") ? "page" : undefined}>Comunidad</a>
          <a href="/blog/" aria-current={isBlog ? "page" : undefined}>Blog</a>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="container footer-inner">
        <p class="footer-label">Una iniciativa de</p>
        <a href={dataScienceUrl} target="_blank" rel="noreferrer" aria-label="Instituto de Data Science UDD">
          <img
            class="data-logo"
            src="/logos/data-science-udd-10-cropped.png"
            alt="Instituto de Data Science UDD 10 años"
            loading="lazy"
          />
        </a>
        <a href={informaticaUrl} target="_blank" rel="noreferrer" aria-label="Informática UDD">
          <img
            class="informatica-logo"
            src="/logos/informatica-udd-cropped.png"
            alt="Informática UDD"
            loading="lazy"
          />
        </a>
      </div>
    </footer>
  </body>
</html>
