---
import "../styles/global.css";
import "../styles/redesign.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  lang?: string;
  robots?: string;
}

const siteName = "Codex para todos";
const defaultDescription =
  "Una comunidad para aprender, practicar y compartir cómo trabajar con Codex sin ser programador.";
const defaultOgImage = "https://codexparatodos.com/images/og-card-codex-landscape.png";
const dataScienceUrl = "https://ingenieria.udd.cl/data-science/";
const informaticaUrl =
  "https://ingenieria.udd.cl/carrera/ingenieria-civil-en-informatica-e-innovacion-tecnologica/";

const {
  title = siteName,
  description = defaultDescription,
  canonical,
  ogImage = defaultOgImage,
  ogType = "website",
  lang = "es",
  robots,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://codexparatodos.com");
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const pageTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const isHome = Astro.url.pathname === "/";
const isBlog = Astro.url.pathname.startsWith("/blog");
const navCopy = lang === "en"
  ? {
      label: "Main navigation",
      home: "Home",
      community: "Community",
      blog: "Blog",
      initiative: "An initiative by",
      dataScience: "UDD Data Science Institute",
      dataScienceAlt: "UDD Data Science Institute 10 years",
      informatica: "UDD Computer Science",
    }
  : {
      label: "Navegación principal",
      home: "Inicio",
      community: "Comunidad",
      blog: "Blog",
      initiative: "Una iniciativa de",
      dataScience: "Instituto de Data Science UDD",
      dataScienceAlt: "Instituto de Data Science UDD 10 años",
      informatica: "Informática UDD",
    };
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {robots ? <meta name="robots" content={robots} /> : null}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/logos/codex-color.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="Codex para todos" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800&family=Fraunces:opsz,wght@9..144,600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <meta name="theme-color" content="#f5f0e6" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Codex para todos: agentes de IA explicados en simple" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Saltar al contenido</a>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href="/" aria-label="Codex para todos">
          <span class="brand-mark" aria-hidden="true">
            <img src="/logos/codex.png" alt="" width="32" height="32" />
          </span>
          <span class="brand-copy">
            <strong>Codex</strong>
            <span>para todos</span>
          </span>
        </a>
        <nav class="site-nav" aria-label={navCopy.label}>
          <a href="/" aria-current={isHome ? "page" : undefined}>{navCopy.home}</a>
          <a href="/comunidad/" aria-current={Astro.url.pathname.startsWith("/comunidad") ? "page" : undefined}>{navCopy.community}</a>
          <a href="/blog/" aria-current={isBlog ? "page" : undefined}>{navCopy.blog}</a>
        </nav>
        <a class="header-cta" href="/comunidad/">
          <span>{lang === "en" ? "Join" : "Participar"}</span>
          <span aria-hidden="true">↗</span>
        </a>
      </div>
    </header>

    <div id="main-content">
      <slot />
    </div>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-statement">
          <p class="footer-kicker">Codex para todos</p>
          <p>{lang === "en" ? "Learn the tools. Keep your judgment." : "Aprender las herramientas. Conservar el criterio."}</p>
        </div>
        <div class="footer-nav" aria-label={lang === "en" ? "Footer navigation" : "Navegación del pie"}>
          <a href="/">{navCopy.home}</a>
          <a href="/comunidad/">{navCopy.community}</a>
          <a href="/blog/">{navCopy.blog}</a>
          <a href="/rss.xml">RSS</a>
        </div>
        <div class="footer-partners">
          <p class="footer-label">{navCopy.initiative}</p>
          <div class="footer-logos">
            <a href={dataScienceUrl} target="_blank" rel="noreferrer" aria-label={navCopy.dataScience}>
              <img class="data-logo" src="/logos/data-science-udd-10-cropped.png" alt={navCopy.dataScienceAlt} loading="lazy" />
            </a>
            <a href={informaticaUrl} target="_blank" rel="noreferrer" aria-label={navCopy.informatica}>
              <img class="informatica-logo" src="/logos/informatica-udd-cropped.png" alt={navCopy.informatica} loading="lazy" />
            </a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
