---
import NewsletterEmbed from "../components/NewsletterEmbed.astro";
import SiteLayout from "../layouts/SiteLayout.astro";

const whatsappUrl = "https://chat.whatsapp.com/IzEnuC9qRl9I51hCqZC1PZ?s=cl&p=i&ilr=2";
const lumaUrl = "https://luma.com/g1d4uxoi";

const title = "Codex para todos";
const description =
  "Una comunidad para aprender, practicar y compartir cómo trabajar con Codex sin ser programador.";
const canonical = "https://codexparatodos.com/";
const ogImage = "https://codexparatodos.com/images/og-card-codex-landscape.png";
---

<SiteLayout title={title} description={description} canonical={canonical} ogImage={ogImage}>
  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="container hero-grid">
        <div class="hero-copy">
          <h1 id="hero-title">Codex para todos</h1>
          <p>
            Aprende, practica y comparte cómo trabajar con Codex sin ser programador.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href={whatsappUrl} target="_blank" rel="noreferrer">
              <svg class="whatsapp-icon" aria-hidden="true" viewBox="0 0 32 32">
                <path
                  fill="currentColor"
                  d="M16.04 4C9.4 4 4 9.4 4 16.04c0 2.12.56 4.2 1.62 6.03L4 28l6.08-1.6a12 12 0 0 0 5.96 1.52h.01c6.64 0 12.04-5.4 12.04-12.04C28.08 9.4 22.68 4 16.04 4Zm.01 21.88h-.01c-1.82 0-3.6-.49-5.16-1.42l-.37-.22-3.6.95.96-3.51-.24-.38a9.9 9.9 0 0 1-1.52-5.26c0-5.5 4.47-9.98 9.96-9.98a9.9 9.9 0 0 1 7.05 2.92 9.9 9.9 0 0 1 2.92 7.05c0 5.5-4.48 9.97-9.99 9.97Zm5.47-7.46c-.3-.15-1.78-.88-2.06-.98-.28-.1-.48-.15-.68.15-.2.3-.78.98-.96 1.18-.18.2-.35.23-.65.08-.3-.15-1.27-.47-2.42-1.5-.9-.8-1.5-1.78-1.67-2.08-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.53.15-.18.2-.3.3-.5.1-.2.05-.38-.02-.53-.08-.15-.68-1.64-.93-2.25-.24-.58-.49-.5-.68-.51h-.58c-.2 0-.53.08-.81.38-.28.3-1.06 1.04-1.06 2.53 0 1.49 1.09 2.93 1.24 3.13.15.2 2.14 3.27 5.18 4.58.72.31 1.29.5 1.73.64.73.23 1.39.2 1.92.12.59-.09 1.78-.73 2.03-1.43.25-.7.25-1.3.18-1.43-.08-.13-.28-.2-.58-.35Z"
                />
              </svg>
              Súmate a la comunidad de WhatsApp
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="meetups-section" aria-labelledby="meetups-title">
      <div class="container">
        <h2 id="meetups-title">Encuentros</h2>
        <div class="meetups-list" aria-label="Encuentros de Codex para todos">
          <div class="meetups-item">
            <h3>Próximos</h3>
            <p>Próximamente</p>
          </div>
          <div class="meetups-item">
            <h3>Pasados</h3>
            <div class="event-row">
              <div>
                <a href="/blog/primer-taller-codex-para-todos/">Primer taller: Codex para todos</a>
                <span>28 de mayo de 2026</span>
              </div>
              <a class="event-secondary-link" href={lumaUrl} target="_blank" rel="noreferrer">
                Ver evento
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <NewsletterEmbed />

    <section id="community" class="community-section" aria-label="Sumarse a la comunidad">
      <div class="container">
        <div class="community-band">
          <div>
            <h2>Súmate a la comunidad</h2>
          </div>
          <a class="button button-light" href={whatsappUrl} target="_blank" rel="noreferrer">
            <svg class="whatsapp-icon" aria-hidden="true" viewBox="0 0 32 32">
              <path
                fill="currentColor"
                d="M16.04 4C9.4 4 4 9.4 4 16.04c0 2.12.56 4.2 1.62 6.03L4 28l6.08-1.6a12 12 0 0 0 5.96 1.52h.01c6.64 0 12.04-5.4 12.04-12.04C28.08 9.4 22.68 4 16.04 4Zm.01 21.88h-.01c-1.82 0-3.6-.49-5.16-1.42l-.37-.22-3.6.95.96-3.51-.24-.38a9.9 9.9 0 0 1-1.52-5.26c0-5.5 4.47-9.98 9.96-9.98a9.9 9.9 0 0 1 7.05 2.92 9.9 9.9 0 0 1 2.92 7.05c0 5.5-4.48 9.97-9.99 9.97Zm5.47-7.46c-.3-.15-1.78-.88-2.06-.98-.28-.1-.48-.15-.68.15-.2.3-.78.98-.96 1.18-.18.2-.35.23-.65.08-.3-.15-1.27-.47-2.42-1.5-.9-.8-1.5-1.78-1.67-2.08-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.53.15-.18.2-.3.3-.5.1-.2.05-.38-.02-.53-.08-.15-.68-1.64-.93-2.25-.24-.58-.49-.5-.68-.51h-.58c-.2 0-.53.08-.81.38-.28.3-1.06 1.04-1.06 2.53 0 1.49 1.09 2.93 1.24 3.13.15.2 2.14 3.27 5.18 4.58.72.31 1.29.5 1.73.64.73.23 1.39.2 1.92.12.59-.09 1.78-.73 2.03-1.43.25-.7.25-1.3.18-1.43-.08-.13-.28-.2-.58-.35Z"
              />
            </svg>
            Entrar al WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
