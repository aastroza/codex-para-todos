---
import "../styles/global.css";

const whatsappUrl = "https://chat.whatsapp.com/HPbQeCcKoMl6rxP4U5gsvF";
const slidesUrl =
  "https://docs.google.com/presentation/d/e/2PACX-1vTMn5OuFUw_QioUS1xm7wXa4wjGgYF4ErwBV2ZS5u2fjqdoTkP863ozdaAijcJ79F1YkblXWCsbEpkC/pubembed?start=false&loop=false&delayms=3000";
const lumaUrl = "https://luma.com/g1d4uxoi";
const dataScienceUrl = "https://ingenieria.udd.cl/data-science/";
const informaticaUrl =
  "https://ingenieria.udd.cl/carrera/ingenieria-civil-en-informatica-e-innovacion-tecnologica/";

const title = "Codex para todos";
const description =
  "Una comunidad para aprender, practicar y compartir cómo trabajar con Codex sin ser programador.";
const canonical = "https://codexparatodos.com/";
const ogImage = "https://codexparatodos.com/images/og-card-codex-para-todos.png";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/logos/codex-color.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ffffff" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Codex para todos" />
    <meta property="og:title" content="Codex para todos" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Codex para todos: agentes de IA explicados en simple" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Codex para todos" />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href="/" aria-label="Codex para todos">
          <img src="/logos/codex.png" alt="" width="32" height="32" />
          <span>Codex para todos</span>
        </a>
        <a class="button button-small header-cta" href={whatsappUrl} target="_blank" rel="noreferrer">
          Entrar al WhatsApp
        </a>
      </div>
    </header>

    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="container hero-grid">
          <div class="hero-copy">
            <h1 id="hero-title">Codex para todos</h1>
            <p>
              Aprende, practica y comparte cómo trabajar con Codex sin ser programador.
            </p>
            <div class="hero-actions">
              <a class="button button-primary" href={whatsappUrl} target="_blank" rel="noreferrer">
                <span aria-hidden="true">↗</span>
                Sumarme a WhatsApp
              </a>
              <a class="text-link" href="#slides">Ver slides del workshop</a>
            </div>
          </div>
        </div>
      </section>

      <section id="slides" class="slides-section" aria-label="Slides del workshop">
        <div class="container">
          <div class="slides-frame">
            <iframe
              src={slidesUrl}
              title="Slides del workshop Codex para todos"
              frameborder="0"
              allowfullscreen
              mozallowfullscreen
              webkitallowfullscreen
            ></iframe>
          </div>
        </div>
      </section>

      <section class="meetups-section" aria-labelledby="meetups-title">
        <div class="container">
          <h2 id="meetups-title">Encuentros</h2>
          <div class="meetups-list" aria-label="Encuentros de Codex para todos">
            <div class="meetups-item">
              <h3>Próximos</h3>
              <p>Próximamente</p>
            </div>
            <div class="meetups-item">
              <h3>Pasados</h3>
              <div class="event-row">
                <span>Workshop inicial: Codex para todos</span>
                <a href={lumaUrl} target="_blank" rel="noreferrer">Ver en Luma</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="community-section" aria-label="Sumarse a la comunidad">
        <div class="container">
          <div class="community-band">
            <div>
              <h2>Súmate a la comunidad</h2>
              <p>El punto de partida es simple: entra al grupo y empieza a practicar con otros.</p>
            </div>
            <a class="button button-light" href={whatsappUrl} target="_blank" rel="noreferrer">
              <span aria-hidden="true">↗</span>
              Entrar al WhatsApp
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <a href={dataScienceUrl} target="_blank" rel="noreferrer" aria-label="Instituto de Data Science UDD">
          <img
            class="data-logo"
            src="/logos/data-science-udd-10-cropped.png"
            alt="Instituto de Data Science UDD 10 años"
            loading="lazy"
          />
        </a>
        <a href={informaticaUrl} target="_blank" rel="noreferrer" aria-label="Informática UDD">
          <img
            class="informatica-logo"
            src="/logos/informatica-udd-cropped.png"
            alt="Informática UDD"
            loading="lazy"
          />
        </a>
      </div>
    </footer>
  </body>
</html>
