---
import SiteLayout from "../layouts/SiteLayout.astro";

const lumaUrl = "https://luma.com/g1d4uxoi";
const photosUrl = "https://photos.app.goo.gl/ziNiMck8oEBo4uxK7";
const videoUrl = "https://youtube.com/shorts/PmifZOeo3jA";
const buildWeekEventUrl = "https://luma.com/siyf8e74";
const dataScienceEventUrl =
  "https://ingenieria.udd.cl/eventos/codex-para-data-science/";
const concepcionEventUrl =
  "https://postgrados.udd.cl/programas/jornada-codex-para-todos-sede-concepcion-245032/";
const concepcionPostUrl = "/blog/codex-para-todos-concepcion/";
const concepcionPhotosUrl = "https://photos.app.goo.gl/fsLPWaY8yNhw23n57";
const upcomingEventSlidesUrl =
  "https://docs.google.com/presentation/d/1esEyAWCHxbHnDHsX7yKopm6QFtEA-3ParRcFK-Sh6kw/edit?usp=sharing";
const showcasePostUrl = "/blog/x-tech-21-showcase-exploratec/";
const upcomingEventImage = "/images/codex-event-concepcion-abstract.webp";
const concepcionEventImage = "/images/evento-concepcion-2026.webp";
const firstWorkshopEventImage = "/images/primer-taller-2026.webp";
const showcaseEventImage = "/images/showcase-exploratec-2026.webp";

const title = "Codex para todos";
const description =
  "Una comunidad para aprender, practicar y compartir cómo trabajar con Codex sin ser programador.";
const canonical = "https://codexparatodos.com/";
const ogImage = "https://codexparatodos.com/images/og-card-codex-landscape.png";
---

<SiteLayout title={title} description={description} canonical={canonical} ogImage={ogImage}>
  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="container hero-grid">
        <div class="hero-copy">
          <h1 id="hero-title">Codex para todos</h1>
          <p>
            Agentes de IA explicados en simple para aprender, practicar y participar sin tener que programar.
          </p>
          <div class="hero-actions" aria-label="Acciones principales">
            <a class="button button-primary" href="/comunidad/">Únete a la comunidad</a>
          </div>
        </div>
      </div>
    </section>

    <section class="events-section upcoming-events-section" aria-labelledby="upcoming-events-title">
      <div class="container">
        <h2 id="upcoming-events-title">Próximos eventos</h2>
        <div class="events-list" aria-label="Próximos encuentros de Codex para todos">
          <article class="event-card event-card-featured" aria-labelledby="build-week-event-title">
            <a class="event-card-media" href={buildWeekEventUrl} target="_blank" rel="noreferrer" aria-label="Ver OpenAI Build Week Community Event - Santiago">
              <img
                src={upcomingEventImage}
                alt="Imagen abstracta en tonos rosados y celestes para OpenAI Build Week Community Event - Santiago"
                width="1200"
                height="675"
                loading="eager"
              />
            </a>
            <div class="event-card-body">
              <h3 id="build-week-event-title">
                <a href={buildWeekEventUrl} target="_blank" rel="noreferrer">OpenAI Build Week Community Event - Santiago</a>
              </h3>
              <dl class="event-card-meta">
                <div>
                  <dt>Fecha</dt>
                  <dd>21 de julio de 2026</dd>
                </div>
                <div>
                  <dt>Horario</dt>
                  <dd>16:00 a 20:00 hrs.</dd>
                </div>
                <div>
                  <dt>Lugar</dt>
                  <dd>Universidad del Desarrollo, Las Condes</dd>
                </div>
              </dl>
              <p>
                Una tarde práctica para explorar cómo ChatGPT, Codex y los agentes de IA pueden ayudarte a trabajar, crear y construir mejor.
              </p>
              <div class="event-card-actions" aria-label="Enlaces de OpenAI Build Week Community Event - Santiago">
                <a href={buildWeekEventUrl} target="_blank" rel="noreferrer">Inscribirme</a>
                <a href={buildWeekEventUrl} target="_blank" rel="noreferrer">Ver detalles</a>
              </div>
            </div>
          </article>

          <article class="event-card event-card-featured" aria-labelledby="data-science-event-title">
            <a class="event-card-media" href={dataScienceEventUrl} target="_blank" rel="noreferrer" aria-label="Ver Codex para Data Science">
              <img
                src={upcomingEventImage}
                alt="Imagen abstracta en tonos rosados y celestes para Codex para Data Science"
                width="1200"
                height="675"
                loading="lazy"
              />
            </a>
            <div class="event-card-body">
              <h3 id="data-science-event-title">
                <a href={dataScienceEventUrl} target="_blank" rel="noreferrer">Codex para Data Science</a>
              </h3>
              <dl class="event-card-meta">
                <div>
                  <dt>Fecha</dt>
                  <dd>20 de julio de 2026</dd>
                </div>
                <div>
                  <dt>Horario</dt>
                  <dd>09:00 a 15:00 hrs.</dd>
                </div>
                <div>
                  <dt>Lugar</dt>
                  <dd>Auditorio AFP Cuprum, Edificio de Postgrado UDD, Las Condes</dd>
                </div>
              </dl>
              <p>
                Un taller práctico para explorar cómo Codex y los agentes de IA pueden apoyar flujos reales de Data Science.
              </p>
              <div class="event-card-actions" aria-label="Enlaces de Codex para Data Science">
                <a href={dataScienceEventUrl} target="_blank" rel="noreferrer">Inscribirme</a>
                <a href={dataScienceEventUrl} target="_blank" rel="noreferrer">Ver detalles</a>
              </div>
            </div>
          </article>

        </div>
      </div>
    </section>

    <section class="events-section past-events-section" aria-labelledby="past-events-title">
      <div class="container">
        <h2 id="past-events-title">Eventos pasados</h2>
        <div class="events-list" aria-label="Encuentros pasados de Codex para todos">
          <article class="event-card" aria-labelledby="concepcion-event-title">
            <a class="event-card-media" href={concepcionPostUrl} aria-label="Leer la nota de Codex para todos en Concepción">
              <img
                src={concepcionEventImage}
                alt="Asistentes de la Jornada Codex para Todos en Concepción durante la presentación"
                width="1200"
                height="675"
                loading="lazy"
              />
            </a>
            <div class="event-card-body">
              <h3 id="concepcion-event-title">
                <a href={concepcionPostUrl}>Jornada Codex para Todos sede Concepción</a>
              </h3>
              <dl class="event-card-meta">
                <div>
                  <dt>Fecha</dt>
                  <dd>14 de julio de 2026</dd>
                </div>
                <div>
                  <dt>Horario</dt>
                  <dd>10:00 a 13:00 hrs.</dd>
                </div>
                <div>
                  <dt>Lugar</dt>
                  <dd>Auditorio AU001, Campus Barros Arana, UDD Concepción</dd>
                </div>
              </dl>
              <p>
                Un taller práctico para entender cómo la IA puede trabajar para ti. No necesitas saber programar.
              </p>
              <div class="event-card-actions" aria-label="Enlaces de la jornada en Concepción">
                <a href={concepcionPostUrl}>Leer nota</a>
                <a href={concepcionEventUrl} target="_blank" rel="noreferrer">Ver detalles</a>
                <a href={concepcionPhotosUrl} target="_blank" rel="noreferrer">Ver fotos</a>
                <a href={upcomingEventSlidesUrl} target="_blank" rel="noreferrer">Slides</a>
              </div>
            </div>
          </article>

          <article class="event-card" aria-labelledby="showcase-event-title">
            <a class="event-card-media" href="/showcase/" aria-label="Ver Showcase ExploraTec">
              <img
                src={showcaseEventImage}
                alt="Alonso Astroza conversando con estudiantes durante el Showcase ExploraTec"
                width="1200"
                height="675"
                loading="lazy"
              />
            </a>
            <div class="event-card-body">
              <h3 id="showcase-event-title">
                <a href="/showcase/">Showcase ExploraTec</a>
              </h3>
              <dl class="event-card-meta">
                <div>
                  <dt>Fecha</dt>
                  <dd>26 de junio de 2026</dd>
                </div>
                <div>
                  <dt>Curso</dt>
                  <dd>Crea tu Agente de IA</dd>
                </div>
              </dl>
              <p>
                Una muestra de proyectos estudiantiles creados con Codex para resolver problemas reales.
              </p>
              <div class="event-card-actions" aria-label="Enlaces del showcase">
                <a href={showcasePostUrl}>Leer nota</a>
                <a href="/showcase/">Ver evento</a>
              </div>
            </div>
          </article>

          <article class="event-card" aria-labelledby="past-event-title">
            <a class="event-card-media" href="/blog/primer-taller-codex-para-todos/" aria-label="Leer la nota del primer taller">
              <img
                src={firstWorkshopEventImage}
                alt="Asistentes del primer taller Codex para todos durante la actividad"
                width="1200"
                height="675"
                loading="lazy"
              />
            </a>
            <div class="event-card-body">
              <h3 id="past-event-title">
                <a href="/blog/primer-taller-codex-para-todos/">Primer taller: Codex para todos</a>
              </h3>
              <dl class="event-card-meta">
                <div>
                  <dt>Fecha</dt>
                  <dd>28 de mayo de 2026</dd>
                </div>
                <div>
                  <dt>Lugar</dt>
                  <dd>Universidad del Desarrollo, Santiago</dd>
                </div>
              </dl>
              <p>
                Codex para transformar la forma de trabajo de quienes no saben programar.
              </p>
              <div class="event-card-actions" aria-label="Enlaces del primer taller">
                <a href="/blog/primer-taller-codex-para-todos/">Leer nota</a>
                <a href={lumaUrl} target="_blank" rel="noreferrer">Ver evento</a>
                <a href={photosUrl} target="_blank" rel="noreferrer">Ver fotos</a>
                <a href={videoUrl} target="_blank" rel="noreferrer">Ver video</a>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
