---
import { getCollection, render, type CollectionEntry } from "astro:content";
import PostCommunityCta from "../../components/PostCommunityCta.astro";
import PostAuthorBio from "../../components/PostAuthorBio.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";

interface Props {
  post: CollectionEntry<"blog">;
}

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const formatDate = new Intl.DateTimeFormat("es-CL", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
const siteUrl = Astro.site ?? new URL("https://codexparatodos.com");
const canonical = new URL(`/blog/${post.id}/`, siteUrl).href;
---

<SiteLayout title={post.data.title} description={post.data.description} canonical={canonical} ogType="article">
  <main>
    <article class="post-page container">
      <a class="back-link" href="/blog/">Volver al blog</a>
      <header class="post-header">
        <time datetime={post.data.pubDate.toISOString()}>
          {formatDate.format(post.data.pubDate)}
        </time>
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>
      </header>
      <div class="post-content">
        <Content />
      </div>
      <PostAuthorBio />
    </article>

    <PostCommunityCta />
  </main>
</SiteLayout>
