---
import SiteLayout from "../layouts/SiteLayout.astro";

const eventUrl = "https://ingenieria.udd.cl/eventos/codex-para-data-science/";
const workshopUrl = "https://github.com/idsudd/codex-para-data-science";
const germanSlidesUrl = "/ds/el-nuevo-flujo-de-trabajo-en-data-science.html";
const alonsoSlidesUrl = "/ds/manos-a-la-obra-con-codex.html";
const cristianSlidesUrl = "/ds/arquitectura-agentica-mas-alla-del-hype.pdf";

const title = "Materiales del taller Codex para Data Science";
const description =
  "Presentaciones y recursos prácticos del taller Codex para Data Science del Instituto de Data Science UDD.";
const canonical = "https://codexparatodos.com/ds/";
---

<SiteLayout title={title} description={description} canonical={canonical}>
  <main class="ds-page">
    <section class="ds-hero" aria-labelledby="ds-title">
      <div class="ds-shell">
        <div class="ds-hero-brand">
          <img
            src="/logos/data-science-udd-10-cropped.png"
            alt="Instituto de Data Science UDD · 10 años"
            width="2517"
            height="649"
          />
        </div>

        <div class="ds-hero-grid">
          <div class="ds-hero-copy">
            <h1 id="ds-title">Codex para<br />Data Science</h1>
            <p class="ds-lead">
              Presentaciones, instrucciones y código para acompañar el trabajo del taller.
            </p>
          </div>

          <div class="ds-hero-aside">
            <p>
              Un taller práctico para explorar cómo Codex y los agentes de IA pueden
              apoyar flujos reales de Data Science.
            </p>
            <a href={eventUrl} target="_blank" rel="noreferrer">
              Ver información del evento
              <span aria-hidden="true">↗</span>
            </a>
          </div>
        </div>

        <div class="ds-route" aria-label="Recorrido del taller">
          <span>Contexto</span>
          <span>Práctica</span>
          <span>Arquitectura</span>
        </div>
      </div>
    </section>

    <section class="ds-materials" aria-labelledby="materials-title">
      <div class="ds-shell">
        <h2 class="sr-only" id="materials-title">Materiales del taller</h2>

        <div class="ds-list">
          <article class="ds-item ds-item-blue">
            <div class="ds-number" aria-hidden="true">01</div>
            <div class="ds-item-copy">
              <p class="ds-label">Presentación · Germán Gómez</p>
              <h3>El nuevo flujo de trabajo en Data Science</h3>
              <p>
                Una mirada al cambio de paradigma: del trabajo asistido por herramientas
                al trabajo coordinado con agentes.
              </p>
            </div>
            <a class="ds-action" href={germanSlidesUrl} target="_blank" rel="noreferrer">
              <span class="ds-action-copy">
                <span class="ds-action-title">Abrir presentación</span>
                <span class="ds-action-meta">HTML interactivo ↗</span>
              </span>
              <span class="ds-action-photo" aria-hidden="true">
                <img src="/ds/speakers/german-gomez.png" alt="" width="750" height="750" loading="lazy" />
              </span>
            </a>
          </article>

          <article class="ds-item ds-item-orange">
            <div class="ds-number" aria-hidden="true">02</div>
            <div class="ds-item-copy">
              <p class="ds-label">Taller práctico · Alonso Astroza</p>
              <h3>Manos a la obra con Codex</h3>
              <p>
                Trabajaremos sobre un repositorio preparado para experimentar con Codex
                en un flujo de Data Science.
              </p>
            </div>
            <a class="ds-action" href={alonsoSlidesUrl} target="_blank" rel="noreferrer">
              <span class="ds-action-copy">
                <span class="ds-action-title">Abrir presentación</span>
                <span class="ds-action-meta">HTML interactivo ↗</span>
              </span>
              <span class="ds-action-photo" aria-hidden="true">
                <img src="/ds/speakers/alonso-astroza.png" alt="" width="400" height="400" loading="lazy" />
              </span>
            </a>
          </article>

          <article class="ds-item ds-item-red">
            <div class="ds-number" aria-hidden="true">03</div>
            <div class="ds-item-copy">
              <p class="ds-label">Presentación · Cristian Candia</p>
              <h3>Trabajo con agentes: cuando «listo» necesita pruebas</h3>
              <p>
                Skills, agentes y flujos que dejan evidencia: una arquitectura para revisar,
                continuar y defender el trabajo.
              </p>
            </div>
            <a class="ds-action" href={cristianSlidesUrl} target="_blank" rel="noreferrer">
              <span class="ds-action-copy">
                <span class="ds-action-title">Abrir presentación</span>
                <span class="ds-action-meta">PDF ↗</span>
              </span>
              <span class="ds-action-photo" aria-hidden="true">
                <img src="/ds/speakers/cristian-candia.png" alt="" width="750" height="750" loading="lazy" />
              </span>
            </a>
          </article>
        </div>
      </div>
    </section>

    <section class="ds-close" aria-label="Cierre">
      <div class="ds-shell ds-close-inner">
        <p>Explora. Prueba. Deja evidencia.</p>
        <a href={workshopUrl} target="_blank" rel="noreferrer">Comenzar el taller <span aria-hidden="true">→</span></a>
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  :global(body) {
    background: #f3f4f0;
  }

  .ds-page {
    --ds-ink: #142139;
    --ds-blue: #1253a4;
    --ds-cyan: #4bb8dc;
    --ds-orange: #ee9e32;
    --ds-red: #c94b40;
    --ds-paper: #f3f4f0;
    color: var(--ds-ink);
    overflow: hidden;
  }

  .ds-shell {
    width: min(1180px, calc(100% - 48px));
    margin-inline: auto;
  }

  .ds-hero {
    position: relative;
    padding: clamp(38px, 6vw, 78px) 0 clamp(58px, 8vw, 104px);
    background:
      linear-gradient(115deg, transparent 0 68%, rgb(75 184 220 / 12%) 68% 100%),
      #f7f8f4;
    border-bottom: 1px solid rgb(20 33 57 / 14%);
  }

  .ds-hero::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: 0;
    width: clamp(90px, 16vw, 230px);
    height: 9px;
    background: linear-gradient(90deg, var(--ds-cyan), var(--ds-orange));
  }

  .ds-hero-brand {
    width: clamp(128px, 13vw, 168px);
  }

  .ds-hero-brand img {
    display: block;
    width: 100%;
    height: auto;
  }

  .ds-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.65fr) minmax(260px, 0.55fr);
    gap: clamp(48px, 9vw, 130px);
    align-items: end;
    padding-top: clamp(82px, 13vw, 166px);
  }

  .ds-eyebrow,
  .ds-label {
    margin: 0 0 18px;
    color: var(--ds-blue);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .ds-hero h1 {
    max-width: 820px;
    margin: 0;
    color: var(--ds-ink);
    font-size: clamp(3.4rem, 8.2vw, 7.3rem);
    font-weight: 700;
    letter-spacing: -0.065em;
    line-height: 0.86;
    text-wrap: balance;
  }

  .ds-lead {
    max-width: 620px;
    margin: clamp(34px, 5vw, 58px) 0 0;
    color: rgb(20 33 57 / 72%);
    font-size: clamp(1.15rem, 1.8vw, 1.42rem);
    line-height: 1.48;
  }

  .ds-hero-aside {
    padding-bottom: 7px;
  }

  .ds-hero-aside p {
    margin: 0 0 28px;
    color: rgb(20 33 57 / 72%);
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .ds-hero-aside a,
  .ds-close a {
    display: inline-flex;
    justify-content: space-between;
    gap: 24px;
    width: 100%;
    padding: 14px 0;
    border-top: 1px solid currentColor;
    color: var(--ds-blue);
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none;
    transition: color 180ms ease, padding 180ms ease;
  }

  .ds-hero-aside a:hover,
  .ds-close a:hover {
    padding-left: 8px;
    color: var(--ds-orange);
  }

  .ds-route {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: clamp(62px, 10vw, 118px);
    border-top: 1px solid rgb(20 33 57 / 16%);
  }

  .ds-route span {
    position: relative;
    padding: 16px 0 0 20px;
    color: rgb(20 33 57 / 54%);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ds-route span::before {
    content: "";
    position: absolute;
    top: -4px;
    left: 0;
    width: 7px;
    height: 7px;
    background: var(--ds-blue);
    border-radius: 50%;
  }

  .ds-route span:nth-child(2)::before { background: var(--ds-orange); }
  .ds-route span:nth-child(3)::before { background: var(--ds-red); }

  .ds-materials {
    padding: clamp(62px, 9vw, 112px) 0 clamp(86px, 12vw, 160px);
    background: var(--ds-paper);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .ds-item {
    --item-accent: var(--ds-blue);
    position: relative;
    display: grid;
    grid-template-columns: 54px minmax(0, 1fr) minmax(300px, 0.58fr);
    gap: clamp(22px, 3.6vw, 48px);
    align-items: center;
    padding: clamp(36px, 5vw, 62px) 0;
    border-bottom: 1px solid rgb(20 33 57 / 20%);
  }

  .ds-number {
    color: rgb(20 33 57 / 42%);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.1em;
  }



  .ds-item-copy h3 {
    max-width: 640px;
    margin: 0 0 18px;
    color: var(--ds-ink);
    font-size: clamp(1.65rem, 3vw, 2.65rem);
    font-weight: 650;
    letter-spacing: -0.035em;
    line-height: 1.08;
    text-wrap: balance;
  }

  .ds-item-copy > p:last-child {
    max-width: 610px;
    margin: 0;
    color: rgb(20 33 57 / 66%);
    font-size: 1rem;
    line-height: 1.6;
  }

  .ds-action {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 118px;
    min-height: 160px;
    padding: 0;
    overflow: hidden;
    background: var(--ds-blue);
    color: #f8faf6;
    text-decoration: none;
    isolation: isolate;
    transition: transform 220ms cubic-bezier(.22, 1, .36, 1), filter 180ms ease;
  }

  .ds-action-copy {
    display: flex;
    flex-direction: column;
    gap: 26px;
    min-width: 0;
    padding: 20px;
  }

  .ds-action-photo {
    position: relative;
    min-width: 0;
    overflow: hidden;
    background: color-mix(in oklch, var(--item-accent), #f8faf6 12%);
  }

  .ds-action-photo::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    background: var(--item-accent);
    mix-blend-mode: screen;
    opacity: 0.34;
  }

  .ds-action-photo img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    filter: grayscale(1) contrast(1.16);
    mix-blend-mode: multiply;
    transition: transform 320ms cubic-bezier(.22, 1, .36, 1);
  }

  .ds-item-orange { --item-accent: #d47a18; }
  .ds-item-red { --item-accent: #aa4038; }
  .ds-item-orange .ds-action { background: #d47a18; }
  .ds-item-red .ds-action { background: #aa4038; }
  .ds-item-orange .ds-label { color: #a9580f; }
  .ds-item-red .ds-label { color: #a33b34; }

  .ds-action:hover {
    transform: translateY(-5px);
    filter: brightness(1.05);
  }

  .ds-action:hover .ds-action-photo img {
    transform: scale(1.035);
  }

  .ds-action:focus-visible,
  .ds-hero-aside a:focus-visible,
  .ds-close a:focus-visible {
    outline: 3px solid var(--ds-orange);
    outline-offset: 4px;
  }

  .ds-action-title {
    font-size: 1.05rem;
    font-weight: 750;
    line-height: 1.2;
  }

  .ds-action-meta {
    margin-top: auto;
    color: rgb(248 250 246 / 78%);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ds-close {
    padding: clamp(62px, 9vw, 108px) 0;
    background: var(--ds-ink);
    color: #f5f6f1;
  }

  .ds-close-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(240px, 0.5fr);
    gap: 64px;
    align-items: end;
  }

  .ds-close p {
    max-width: 720px;
    margin: 0;
    font-size: clamp(2.6rem, 6vw, 5.8rem);
    font-weight: 650;
    letter-spacing: -0.055em;
    line-height: 0.98;
  }

  .ds-close a {
    color: var(--ds-cyan);
  }

  @media (max-width: 980px) {
    .ds-item {
      grid-template-columns: 42px minmax(0, 1fr);
      align-items: start;
    }

    .ds-action {
      grid-column: 2;
      min-height: 150px;
    }
  }

  @media (max-width: 820px) {
    .ds-shell { width: min(100% - 32px, 680px); }
    .ds-hero-grid,
    .ds-close-inner { grid-template-columns: 1fr; }
    .ds-hero-grid { gap: 48px; }
    .ds-hero-aside { max-width: 420px; }
  }

  @media (max-width: 620px) {
    .ds-hero h1 { font-size: clamp(3.2rem, 17vw, 5.3rem); }
    .ds-route { gap: 10px; }
    .ds-route span { padding-left: 0; font-size: 0.65rem; }
    .ds-route span::before { left: 0; }
    .ds-item {
      grid-template-columns: 1fr;
      gap: 22px;
    }
    .ds-number,
    .ds-item-copy,
    .ds-action { grid-column: 1; }
    .ds-action { grid-template-columns: minmax(0, 1fr) 112px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ds-action,
    .ds-hero-aside a,
    .ds-close a { transition: none; }
  }
</style>
